
library(readxl)
library(dplyr)
library(magrittr)
library(ggplot2)
library(stringr)
# library(ggthemes)

newhire <- read_excel (
  "newhire2025.xlsx",
  sheet = 1
)

tasks <- read_excel (
  "fullreporttasks.xlsx",
  sheet = 1
)
##Task filtering
taskfilter <- tasks %>%
  filter(quarter == "Q4 2025") %>%
  filter(!`Case Manager Name` %in% c("MCKENZI RIDDELL"))

taskfilterallquarters <- tasks %>%
  filter(!`Case Manager Name` %in% c("MCKENZI RIDDELL"))

task_clean <- taskfilter %>%
  rename(
    manager = `Case Manager Name`)
##task counts by status Q4
taskcountsstatus <- task_clean %>%
  group_by(manager, RSN_CD) %>%
  summarise(status = n(), .groups = "drop")
##task count total per manager Q4
taskmanagercount <- task_clean %>%
  count(manager, name = "taskcount")
##task count total team per quarter
taskquartercount <- taskfilterallquarters %>%
  count(quarter, name = "taskcount")
##Task count Q4 by month
taskmonthcount <- task_clean %>%
  count(month, name = "taskcount")


newhiresubmittedthroughfile <- newhire %>%
  mutate (
    code1 = as.numeric(code1)
  ) %>%
  group_by(Quarter) %>%
  summarize(code1_sum = sum(code1, na.rm = TRUE), .groups = 'drop')

newhiresubmittedindividually <- newhire %>%
  mutate (
    code2 = as.numeric(code2)
  ) %>%
  group_by(Quarter) %>%
  summarize(code2_sum = sum(code2, na.rm = TRUE), .groups = 'drop')


totalnewhires <- newhire %>%
  mutate (
    code3 = as.numeric(code3)
  ) %>%
  group_by(Quarter) %>%
  summarize(code3_sum = sum(code3, na.rm = TRUE), .groups = 'drop')

numberofcompanies <- newhire %>%
  mutate (
    code4 = as.numeric(code4)
  ) %>%
  group_by(Quarter) %>%
  summarize(
    code4_sum = sum(code4, na.rm = TRUE),
    .groups = 'drop'
    )


