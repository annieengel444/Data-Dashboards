newhirefiletest <- ggplot(newhiresubmittedthroughfile, aes(x = Quarter, y = code1_sum, fill = Quarter)) +  ##color = manager##color = manager Note color = manager
  geom_col(color = "grey22") + ##Type of graph fill = "lightgrey"
  theme_classic() + ##Graph overall theme
  scale_fill_manual(values = DCS_colors3) +
  geom_text ( ##Data count labels on the bars
    aes(label = scales::comma(code1_sum)),
    vjust = -0.3,
    size = 10,
    color = "grey22"
  ) +
  theme( ##Here edits the text size of the x and y and titles
    axis.text.x = element_text(size = 20, color = "#00324a"),##text of the x variable
    axis.text.y  = element_text(size = 15, color = "#00324a85"),
    axis.title.x = element_text(size = 16, face = "bold", hjust = 0.5, color = "#00324a"),##x variable title
    axis.title.y = element_text(size = 16, face = "bold", hjust = 0.5, color = "#00324a"),##y variable title
    plot.title = element_text(size = 25, face = "bold", hjust = 0.5, color = "#00324a"), ##plot title, hjust is where its positioned
    plot.subtitle = element_text(size = 17, face = "bold", hjust = 0.5, color = "#00324a85"), ##plot title, hjust is where its positioned
    legend.position = "none" ##excludes the legend in the final output
  ) +
  scale_x_discrete(labels = function(x) str_wrap(x, width = 12)) + ##Wrapping labels if theyre too long/ dont  run into each other
  labs ( ##labeling/ titles
    x = "Quarter",
    y = "New Hires",
    title = "Total New Hire Submitted Through File Per Quarter",
    subtitle = "Employer Services- Year Review 2025"
  )

